# ============================================================
# SecureVault — Environment Variable Template
# ============================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
#
# Usage (Linux/macOS):
#   cp .env.example .env
#   nano .env
#   export $(grep -v '^#' .env | xargs)
#   python app.py
#
# Usage (Windows PowerShell):
#   $env:SECRET_KEY="your-secret-here"
#   $env:FLASK_ENV="production"
#   python app.py
# ============================================================

# REQUIRED — Generate with: python -c "import secrets; print(secrets.token_hex(48))"
SECRET_KEY=CHANGE_ME_TO_A_LONG_RANDOM_HEX_STRING

# Application environment: "production" or "development"
FLASK_ENV=production

# Optional overrides (defaults shown)
# UPLOAD_FOLDER=./uploads
# DATABASE=./instance/filestore.db
